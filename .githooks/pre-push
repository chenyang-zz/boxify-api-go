#!/usr/bin/env bash
#
# pre-push hook: 推送前运行与 Cove CI 一致的本地校验。
# 跳过方式：GIT_PUSH_VERIFY=false git push
set -euo pipefail

if [ "${GIT_PUSH_VERIFY:-}" = "false" ]; then
  echo "[pre-push] 跳过校验 (GIT_PUSH_VERIFY=false)"
  exit 0
fi

ROOT=$(git rev-parse --show-toplevel)
SERVER_DIR="$ROOT/packages/server"
APP_DIR="$ROOT/packages/app"
FRONTEND_DIR="$APP_DIR/frontend"
MOBILE_DIR="$APP_DIR/mobile"
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
FULL_VERIFY=false

case "$CURRENT_BRANCH" in
  main|dev) FULL_VERIFY=true ;;
esac

echo "[pre-push] 开始 Cove monorepo 校验..."

echo "  ▸ Server gofmt"
files=$(gofmt -l "$SERVER_DIR")
if [ -n "$files" ]; then
  echo "[pre-push] 以下文件需要 gofmt 格式化："
  echo "$files"
  exit 1
fi

echo "  ▸ Server vet / build"
(
  cd "$SERVER_DIR"
  go vet ./...
  go build ./...
)

echo "  ▸ Server codegen checks"
(
  cd "$SERVER_DIR"
  go run ./cmd/codegen route --check --format json >/dev/null
  go run ./cmd/codegen repository --list-models --format json >/dev/null
  go run ./cmd/codegen docs --check --format json >/dev/null
  go run ./cmd/codegen prompt --check --format json >/dev/null
  go run ./cmd/codegen doctor --format json >/dev/null
)

if [ "$FULL_VERIFY" = true ]; then
  command -v pnpm >/dev/null || {
    echo "[pre-push] pnpm 未安装，无法验证 App" >&2
    exit 1
  }

  echo "  ▸ Server tests / vulnerability check"
  (
    cd "$SERVER_DIR"
    go test -count=1 -race ./...
    go run golang.org/x/vuln/cmd/govulncheck@latest ./...
  )

  echo "  ▸ Web tests / build"
  (
    cd "$FRONTEND_DIR"
    pnpm test
    pnpm build
  )

  echo "  ▸ Desktop Go tests"
  (
    cd "$APP_DIR"
    go test ./...
  )

  echo "  ▸ Mobile lint / typecheck / tests"
  (
    cd "$MOBILE_DIR"
    pnpm lint
    pnpm typecheck
    pnpm test
  )
fi

echo "[pre-push] ✅ 校验通过，允许推送。"
